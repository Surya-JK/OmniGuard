# OmniGuard Test Suite — Environment Variables
# Copy this file to .env and fill in your values.
# Both appium/ and selenium/ directories look for these variables.

# ── Supabase Test Account ──────────────────────────────────
# Create a dedicated test account in your Supabase project.
OMNIGUARD_TEST_EMAIL=testuser@omniguard.dev
OMNIGUARD_TEST_PASSWORD=TestPass123!

# ── Appium ────────────────────────────────────────────────
APPIUM_SERVER_URL=http://127.0.0.1:4723
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=14.0

# Optional: full path to the OmniGuard .apk file
# Leave blank to use the already-installed app on the device.
# OMNIGUARD_APK_PATH=C:\path\to\OmniGuard.apk

# ── Selenium ──────────────────────────────────────────────
# Live Vercel deployment:
OMNIGUARD_WEB_URL=https://omni-guard-beta.vercel.app
# Local dev server:
# OMNIGUARD_WEB_URL=http://localhost:8081

SELENIUM_BROWSER=chrome          # chrome | firefox
SELENIUM_HEADLESS=false          # true for CI/CD pipelines
