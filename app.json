{
  "expo": {
    "name": "OmniGuard",
    "slug": "OmniGuard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "omniguard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1120",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.surya06.omniguard"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow OmniGuard to access your camera to scan physical receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow OmniGuard to access your photos to scan for scam messages and forged receipts."
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "*/*"
          ],
          "androidMultiIntentFilters": [
            "*/*"
          ]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1120",
          "dark": {
            "backgroundColor": "#0B1120"
          }
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/OmniGuard"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44e2e76b-4e52-43fc-8f01-c91bf86bf6f1"
      }
    }
  }
}
